rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.fullName is string &&
             data.updatedAt is timestamp;
    }

    function isValidBooking(data) {
      return data.id is string &&
             data.type is string &&
             data.date is string &&
             data.time is string &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidPoint(data) {
      return data.id is string &&
             data.location_name is string &&
             data.total_slots is int &&
             data.occupied_slots is int &&
             data.occupied_slots >= 0 &&
             data.occupied_slots <= data.total_slots;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    match /users/{userId}/bookings/{bookingId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidBooking(incoming());
      allow delete: if isOwner(userId);
    }

    match /mentor_applications/{applicationId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /centauri_points/{pointId} {
      allow read: if isSignedIn();
      // Only admins can modify point data
      allow write: if isAdmin() && isValidPoint(incoming());
    }

    match /admins/{adminId} {
      allow read, write: if false; // System only
    }

    match /lockers/{lockerId} {
      allow read, write: if false; // Deprecated
    }

    match /laptops/{assetTag} {
      allow read: if isSignedIn() && (existing().assignedTo == request.auth.uid);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }
  }
}
